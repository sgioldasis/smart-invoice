rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authorized
    function isAuthorized() {
      return request.auth != null && request.auth.token.email == 's.gioldasis@gmail.com';
    }
    
    // Helper function to check if user owns the resource by userEmail
    function isOwnerByEmail(userEmail) {
      return request.auth != null && request.auth.token.email == userEmail;
    }
    
    // Helper function to check ownership (only userEmail)
    // Allow if userEmail matches OR if userEmail is missing (legacy)
    function isOwner(data) {
      return data.get('userEmail', null) == null || isOwnerByEmail(data.userEmail);
    }
    
    // Clients collection
    match /clients/{clientId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
    
    // Work Records collection
    match /workRecords/{workRecordId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
    
    // Documents collection
    match /documents/{documentId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
    
    // Timesheets collection (WorkRecordTimesheets)
    match /timesheets/{timesheetId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
    
    // Work Record Timesheets collection (alternative name)
    match /workRecordTimesheets/{timesheetId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
    
    // Templates collection
    match /templates/{templateId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isOwner(request.resource.data);
      allow update: if isAuthorized() && isOwner(resource.data);
      allow delete: if isAuthorized() && isOwner(resource.data);
    }
  }
}